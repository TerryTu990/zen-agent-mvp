# /root/zen-agent/.env 模板：复制为 .env 后在服务器上填真值。
# 真值 MUST NOT 入仓、不经开发机传输（ZA-C-SEC-01/02）。

# --- 必填 secret ---
ZA_JWT_SECRET=
ZA_SIGNING_SECRET=

# --- LLM 上游（openai 兼容）---
ZA_LLM_BASE_URL=
ZA_LLM_API_KEY=
ZA_LLM_MODEL=

# --- 部署参数 ---
# 镜像 tag（deploy-server.sh 每次部署会更新此值为当次 git SHA）
ZA_IMAGE_TAG=latest
# 扩展来源收敛 CORS（chrome 扩展 origin 形如 chrome-extension://<id>；未定则先 *）
ZA_CORS_ORIGIN=*
# JWT 签发方白名单（逗号分隔）
ZA_JWT_ISS_ALLOWLIST=zen-agent-demo
# 跨站任务回合较多
ZA_MAX_TURN_ROUNDS=40

# --- server 通道宿主凭证（工具 credentialRef 对应项，按需）---
# ZA_CRED_CODEFLOW_PLATFORM_KEY=

# --- 演示端点（生产保持关闭）---
# ZA_DEMO_TOKEN_ENABLED=1
