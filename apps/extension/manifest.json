{
  "manifest_version": 3,
  "name": "zen-agent",
  "version": "0.1.0",
  "description": "宿主系统功能辅助智能体（讲解 / UI 引导 / API 调用协助）",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "zen",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": ["storage", "activeTab", "tabGroups"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*", "https://codeflow.asia/*"],
  "content_scripts": [
    {
      "matches": ["http://127.0.0.1/*", "http://localhost/*", "https://codeflow.asia/*"],
      "js": ["dist/content.js"]
    }
  ]
}
