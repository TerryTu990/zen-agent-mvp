{
  "manifest_version": 3,
  "name": "zen-agent",
  "version": "0.1.0",
  "description": "宿主系统功能辅助智能体（讲解 / UI 引导 / API 调用协助）",
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "zen-agent"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*", "https://codeflow.asia/*"],
  "content_scripts": [
    {
      "matches": ["http://127.0.0.1/*", "http://localhost/*", "https://codeflow.asia/*"],
      "js": ["dist/content.js"]
    }
  ]
}
