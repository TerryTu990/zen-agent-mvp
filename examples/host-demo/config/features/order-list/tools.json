[
  {
    "id": "order-list.cancel-order",
    "featureIds": ["order-list"],
    "description": "取消一笔待发货订单。仅当用户明确要求取消且给出订单号时调用；orderId 为订单列表中的订单号（如 ORD-1001）。已完成订单不可取消，不要对其调用本工具。",
    "params": {
      "type": "object",
      "additionalProperties": false,
      "required": ["orderId"],
      "properties": {
        "orderId": {
          "type": "string",
          "pattern": "^ORD-[0-9]+$",
          "description": "要取消的订单号"
        }
      }
    },
    "execution": "client",
    "riskTier": "hitl",
    "adapter": {
      "method": "POST",
      "urlTemplate": "/api/orders/{{orderId}}/cancel"
    },
    "resultSchema": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "orderId"],
      "properties": {
        "ok": { "type": "boolean" },
        "orderId": { "type": "string" }
      }
    }
  },
  {
    "id": "order-list.refresh-orders",
    "featureIds": ["order-list"],
    "description": "刷新订单列表：重新拉取当前用户的订单数据并更新页面。当用户要求刷新、重新加载或更新订单列表时调用；无需参数，可直接执行。",
    "params": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    },
    "execution": "client",
    "riskTier": "auto",
    "adapter": {
      "method": "GET",
      "urlTemplate": "/api/orders"
    },
    "resultSchema": {
      "type": "object",
      "required": ["ok"],
      "properties": {
        "ok": { "type": "boolean" },
        "count": { "type": "number" }
      }
    }
  },
  {
    "id": "order-list.purge-orders",
    "featureIds": ["order-list"],
    "description": "清空全部订单（不可逆的批量删除，高危操作）。此工具仅用于声明该能力的存在，实际被禁止执行；即便用户要求清空或删除所有订单也不会真正执行。",
    "params": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    },
    "execution": "client",
    "riskTier": "forbidden",
    "adapter": {
      "method": "DELETE",
      "urlTemplate": "/api/orders"
    },
    "resultSchema": {
      "type": "object",
      "required": ["ok"],
      "properties": {
        "ok": { "type": "boolean" }
      }
    }
  }
]
