[
  {
    "id": "order-list.cancel-order",
    "featureIds": [
      "order-list"
    ],
    "description": "取消一笔待发货订单。仅当用户明确要求取消且给出订单号时调用；orderId 为订单列表中的订单号（如 ORD-1001）。已完成订单不可取消，不要对其调用本工具。",
    "params": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "orderId"
      ],
      "properties": {
        "orderId": {
          "type": "string",
          "pattern": "^ORD-[0-9]+$",
          "description": "要取消的订单号"
        }
      }
    },
    "execution": "client",
    "riskTier": "hitl",
    "adapter": {
      "method": "POST",
      "urlTemplate": "/api/orders/{{orderId}}/cancel"
    },
    "resultSchema": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ok",
        "orderId"
      ],
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "orderId": {
          "type": "string"
        }
      }
    }
  },
  {
    "id": "order-list.refresh-orders",
    "featureIds": [
      "order-list"
    ],
    "description": "刷新订单列表：重新拉取当前用户的订单数据并更新页面。当用户要求刷新、重新加载或更新订单列表时调用；无需参数，可直接执行。",
    "params": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    },
    "execution": "client",
    "riskTier": "auto",
    "adapter": {
      "method": "GET",
      "urlTemplate": "/api/orders"
    },
    "resultSchema": {
      "type": "object",
      "required": [
        "ok"
      ],
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "count": {
          "type": "number"
        }
      }
    }
  },
  {
    "id": "order-list.purge-orders",
    "featureIds": [
      "order-list"
    ],
    "description": "清空全部订单（不可逆的批量删除，高危操作）。此工具仅用于声明该能力的存在，实际被禁止执行；即便用户要求清空或删除所有订单也不会真正执行。",
    "params": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    },
    "execution": "client",
    "riskTier": "forbidden",
    "adapter": {
      "method": "DELETE",
      "urlTemplate": "/api/orders"
    },
    "resultSchema": {
      "type": "object",
      "required": [
        "ok"
      ],
      "properties": {
        "ok": {
          "type": "boolean"
        }
      }
    }
  },
  {
    "id": "order-list.page-operate",
    "featureIds": [
      "order-list"
    ],
    "description": "在订单页面上可见地代用户操作（填写/点击/读取）。当用户要求\"替我在页面上操作\"时使用；操作前必须先调用 page_snapshot 获取可交互元素 ref，steps 中的 ref 必须取自最近一次快照；需要向用户回报的值用 read 步骤采集。 调用约定：先在文本中向用户说明将进行的功能级步骤；task 在整个任务期间保持不变（首批触发一次用户授权，其后同任务批次自动放行）。",
    "params": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task",
        "steps",
        "summary"
      ],
      "properties": {
        "task": {
          "type": "string",
          "description": "任务标题（功能级，如\"创建令牌 e2e-dom\"）。同一任务的所有批次保持同一标题——用户按它授权一次后，本任务后续批次自动执行"
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object"
          }
        },
        "summary": {
          "type": "string",
          "description": "面向用户的操作摘要（将展示在确认卡上）"
        }
      }
    },
    "execution": "client",
    "riskTier": "auto",
    "adapter": {
      "kind": "dom",
      "pathPrefixes": [
        "/order-list"
      ]
    },
    "resultSchema": {
      "type": "object",
      "required": [
        "reads",
        "completedSteps"
      ],
      "properties": {
        "reads": {
          "type": "object"
        },
        "completedSteps": {
          "type": "number"
        }
      }
    }
  }
]
