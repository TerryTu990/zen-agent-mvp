[
  {
    "id": "xianyu-seller-data.page-operate",
    "featureIds": ["xianyu-seller-data"],
    "description": "在闲鱼卖家数据总览上可见地展开菜单、切换页面、选择时间筛选或读取页面值。使用前必须 page_snapshot，steps 中每个 ref 取自最近快照；折叠菜单须先展开父项并在下一批重新快照；本工具不得用聚合数据判断单个订单付款状态。每批后重新 page_snapshot 复核。",
    "params": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task", "steps", "summary"],
      "properties": {
        "task": { "type": "string", "description": "任务标题，同一任务期间保持不变" },
        "plan": { "type": "array", "items": { "type": "string" }, "description": "首批操作的功能级计划" },
        "steps": { "type": "array", "minItems": 1, "maxItems": 8, "items": { "type": "object" }, "description": "操作步骤：click|select|read|scroll|highlight；ref 必须来自最近快照" },
        "summary": { "type": "string", "description": "展示给用户的本批操作摘要" }
      }
    },
    "execution": "client",
    "riskTier": "hitl",
    "adapter": { "kind": "dom", "pathPrefixes": ["/"] },
    "resultSchema": {
      "type": "object",
      "properties": {
        "reads": { "type": "object" },
        "completedSteps": { "type": "number" },
        "url": { "type": "string" }
      }
    }
  }
]
